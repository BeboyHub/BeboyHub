-- ==================== ESP System Logic ====================
local drawings = {}
local function createESP(plr)
    local box = Drawing.new("Square")
    local name = Drawing.new("Text")
    
    RS.RenderStepped:Connect(function()
        if ESP_Enabled and plr ~= lp and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                if ESP_Boxes then
                    local size = 2000 / pos.Z
                    box.Visible = true
                    box.Size = Vector2.new(size, size * 1.5)
                    box.Position = Vector2.new(pos.X - (size / 2), pos.Y - (size * 0.75))
                    box.Color = FOV_Color
                else box.Visible = false end
                
                if ESP_Names then
                    name.Visible = true
                    name.Text = plr.Name
                    name.Position = Vector2.new(pos.X, pos.Y - (1300 / pos.Z))
                    name.Center = true
                    name.Outline = true
                    name.Size = 14
                else name.Visible = false end
            else box.Visible, name.Visible = false, false end
        else box.Visible, name.Visible = false, false end
        
        if not plr.Parent then box:Remove() name:Remove() end
    end)
end
for _, v in pairs(Players:GetPlayers()) do createESP(v) end
Players.PlayerAdded:Connect(createESP)

