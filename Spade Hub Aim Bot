-- ==================== Main Loop (Aim & FOV) ====================
RS.RenderStepped:Connect(function()
    -- Update FOV Circle
    FOVCircle.Visible = FOV_Visible
    FOVCircle.Radius = FOV_Radius
    FOVCircle.Position = UserInputService:GetMouseLocation()
    FOVCircle.Color = FOV_Color

    -- Aimlock Logic
    if AimlockEnabled then
        local target = nil
        local shortestDist = FOV_Radius 
        
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild(AimPart) then
                local pos, onScreen = Camera:WorldToViewportPoint(v.Character[AimPart].Position)
                if onScreen then
                    local mousePos = UserInputService:GetMouseLocation()
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    
                    if dist < shortestDist then
                        shortestDist = dist
                        target = v
                    end
                end
            end
        end
        
        if target then
            Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Character[AimPart].Position)
        end
    end
end)


