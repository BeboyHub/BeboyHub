local function FireBridge(...)
    local args = {...}
    args.n = #args
    pcall(function() BridgeNetEvent:FireServer({args, "\x02"}) end)
end

local function GetGachaCFrame(target, offsetX, offsetZ)
    local root = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart
    if root then return root.CFrame * CFrame.new(offsetX, 4, offsetZ) end
    return target:GetPivot() * CFrame.new(offsetX, 4, offsetZ)
end

local function teleportToGamemodeNPC(mapId, keywords)
    pcall(function()
        local mapFolder = workspace._MAP:WaitForChild(tostring(mapId), 5)
        if not mapFolder then return end
        
        local interactions = mapFolder:WaitForChild("Interactions", 5)
        if not interactions then return end

        local targets = {}
        for _, v in ipairs(interactions:GetChildren()) do table.insert(targets, v) end
        if interactions:FindFirstChild("Gamemode") then
            for _, v in ipairs(interactions.Gamemode:GetChildren()) do table.insert(targets, v) end
        end

        for _, v in ipairs(targets) do
            local name = string.lower(tostring(v.Name))
            local attrName = string.lower(tostring(v:GetAttribute("Name") or ""))
            local attrId = string.lower(tostring(v:GetAttribute("Id") or ""))
            
            for _, kw in ipairs(keywords) do
                local lowerKw = string.lower(kw)
                if string.find(name, lowerKw) or string.find(attrName, lowerKw) or string.find(attrId, lowerKw) then
                    if player.Character and player.Character.PrimaryPart then
                        player.Character.PrimaryPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        player.Character.PrimaryPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                        
                        local targetPart = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Rig") or v:FindFirstChild("Range") or v
                        local cf = targetPart:IsA("Model") and targetPart:GetPivot() or targetPart.CFrame
                        
                        player.Character:SetPrimaryPartCFrame(cf * CFrame.new(0, 3, 0))
                    end
                    return true
                end
            end
        end
    end)
end

local function hasTokenAmountToRoll(token)
    local check = false
    pcall(function()
        local PlayerData = ScriptLibrary and ScriptLibrary.PlayerData
        if not PlayerData then return end
        local VIPGamepass = PlayerData.Gamepasses and PlayerData.Gamepasses.VIPGamepass
        local inventory = PlayerData.Inventory
        if not inventory then return end
        local amountNeeded = VIPGamepass and 7 or 10
        local tokenAmount = inventory[token]
        if tokenAmount and tonumber(tokenAmount) >= amountNeeded then check = true end
    end)
