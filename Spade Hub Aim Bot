local function getQuests()
    local quests = {}
    pcall(function()
        local questGui = player.PlayerGui:FindFirstChild("SideGUI") and player.PlayerGui.SideGUI:FindFirstChild("Content") and player.PlayerGui.SideGUI.Content:FindFirstChild("ActiveQuest")
        if questGui then
            for _, obj in ipairs(questGui:GetDescendants()) do
                if obj:IsA("TextLabel") then
                    local text = obj.Text
                    if text:find("Defeat") then
                        local npc = text:gsub("Defeat%s*", ""):match("^[^%[]+")
                        npc = npc and npc:match("^%s*(.-)%s*$")
                        local inside = text:match("%[(.-)%]")
                        if inside then
                            local current, required = inside:match("(%d+)%/(%d+)")
                            if current and required then
                                table.insert(quests, {
                                    npc = npc,
                                    current = tonumber(current),
                                    required = tonumber(required),
                                })
                            end
                        end
                    end
                end
            end
        end
    end)
    return quests
end

local function autoQuestFunction()
    while getgenv().autoQuestEnabled do
        local quests = getQuests()
        for i, quest in ipairs(quests) do
            while quest.current < quest.required and getgenv().autoQuestEnabled do
                local targetUid = nil
                local clientEnemies = workspace:FindFirstChild("_ENEMIES") and workspace._ENEMIES:FindFirstChild("Client")
                local serverEnemies = workspace:FindFirstChild("_ENEMIES") and workspace._ENEMIES:FindFirstChild("Server")

                if clientEnemies then
                    for _, enemy in pairs(clientEnemies:GetChildren()) do
                        if enemy.Name ~= "Highlight" then
                            local billboard = enemy:FindFirstChild("EnemyBillboard", true)
                            if billboard and billboard:FindFirstChild("Title") then
                                local mName = billboard.Title.Text:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
                                if mName == quest.npc then
                                    targetUid = enemy.Name
                                    break
                                end
                            end
                        end
                    end
                end

                if targetUid and serverEnemies then
                    local mapFolder = serverEnemies:FindFirstChild(tostring(playerMap))
                    if mapFolder then
                        local serverPart = mapFolder:FindFirstChild(targetUid)
                        if serverPart and serverPart:IsA("BasePart") then
                            local char = player.Character
                            local myRoot = char and char:FindFirstChild("HumanoidRootPart")
                            if myRoot then
                                myRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                myRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                local targetPos = serverPart.Position
                                local offsetPos = targetPos + Vector3.new(0, 4, 3)
                                myRoot.CFrame = CFrame.new(offsetPos, Vector3.new(targetPos.X, offsetPos.Y, targetPos.Z))
                            end
                            local hp = serverPart:GetAttribute("HP")
                            if hp and hp > 0 then
                                FireBridge("ClickSystem", "Execute", tostring(targetUid))
                            end
                        end
                    end
                end
                task.wait(0.5)
                quests = getQuests()
                quest = quests[i]
                if not quest then break end
            end
        end
        task.wait(1)
    end
end

