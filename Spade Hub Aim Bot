local function CreateAutoLeave(selectedWaveVar, teleportDest)
    return function()
        local toggleName = "autoLeave" .. selectedWaveVar:gsub("selectedWave", "") .. "WaveXEnabled"
        while getgenv()[toggleName] do
            pcall(function()
                local modeGui = player.PlayerGui:FindFirstChild("Mode")
                if modeGui and modeGui:FindFirstChild("Content") then
                    local possibleWaves = {}
                    
                    for _, desc in ipairs(modeGui.Content:GetDescendants()) do
                        if desc:IsA("TextLabel") and desc.Visible then
                            local txt = desc.Text:gsub("<[^>]+>", "")
                            local lTxt = string.lower(txt)
                            local dName = string.lower(desc.Name)
                            local pName = string.lower(desc.Parent and desc.Parent.Name or "")
                            
                            if string.find(lTxt, "start") or string.find(lTxt, "in ") or string.find(lTxt, "cooldown") then
                                continue
                            end
                        
                            local curr, mx = string.match(lTxt, "(%d+)%s*/%s*(%d+)")
                            if curr then 
                                table.insert(possibleWaves, tonumber(curr))
                                continue
                            end
                            
                            local wMatch = string.match(lTxt, "wave%s*[:%-]?%s*(%d+)")
                            if wMatch then 
                                table.insert(possibleWaves, tonumber(wMatch))
                                continue
                            end
        
                            if string.find(pName, "wave") or string.find(dName, "wave") then
                                local exactMatch = string.match(lTxt, "^%s*(%d+)%s*$")
                                if exactMatch then
                                
                                    if not string.find(dName, "max") and not string.find(pName, "max") then
                                        table.insert(possibleWaves, tonumber(exactMatch))
                                    end
                                end
                            end
                        end
                    end
        
                    if #possibleWaves > 0 then
                        local currentWave = math.huge
                        for _, v in ipairs(possibleWaves) do
                            if v > 0 and v < currentWave then 
                                currentWave = v 
                            end
                        end
                        
                        local selectedWave = tonumber(getgenv()[selectedWaveVar]) or 1
                        if currentWave ~= math.huge and currentWave >= selectedWave then
                            Notify("Auto Leave Triggered! Reached Wave: " .. tostring(currentWave), 5)
                            FireBridge("TeleportSystem", "To", teleportDest)
                            task.wait(5)
                        end
                    end
                end
            end)
            task.wait(1)
        end
    end
end

