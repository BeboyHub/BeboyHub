end

local function getUnitsAndSwords()
    local pList, pDict = {}, {}
    local wList, wDict = {}, {}
    pcall(function()
        local pData = ScriptLibrary.PlayerData
        if pData.Pets then
            for uuid, data in pairs(pData.Pets) do
                local name = tostring(data.Id or data.Name or "Unknown")
                local level = data.Level and (" [Lv."..data.Level.."]") or ""
                local passive = (data.Buffs and data.Buffs.Passive) or data.Passive or data.Trait or (data.Buffs and data.Buffs["Easter Passive"]) or data["Easter Passive"] or ""
                if passive ~= "" then passive = " ("..passive..")" end
                local equipped = data.Equipped and " [E]" or ""
                
                local label = name .. level .. passive .. equipped .. " [" .. tostring(uuid):sub(1,6) .. "]"
                table.insert(pList, label)
                pDict[label] = uuid
            end
        end
        if pData.Weapons then
            for uuid, data in pairs(pData.Weapons) do
                local name = tostring(data.Id or data.Name or "Unknown")
                local level = data.Level and (" [Lv."..data.Level.."]") or ""
                local enchant = (data.Buffs and data.Buffs.Enchantment) or data.Enchantment or (data.Buffs and data.Buffs["Easter Enchantment"]) or data["Easter Enchantment"] or ""
                if enchant ~= "" then enchant = " ("..enchant..")" end
                local equipped = data.Equipped and " [E]" or ""
                
                local label = name .. level .. enchant .. equipped .. " [" .. tostring(uuid):sub(1,6) .. "]"
                table.insert(wList, label)
                wDict[label] = uuid
            end
        end
    end)
    if #pList == 0 then table.insert(pList, "No Pets Found") end
    if #wList == 0 then table.insert(wList, "No Swords Found") end
    table.sort(pList)
    table.sort(wList)
    return pList, pDict, wList, wDict
end

