local function getTopPriorityTask()
    if not getgenv().enablePrioritySystem then return nil end
    local priorities = {
        getgenv().priority1, getgenv().priority2, getgenv().priority3,
        getgenv().priority4, getgenv().priority5
    }
    
    for _, taskName in ipairs(priorities) do
        if taskName and taskName ~= "None" then
            local envKey = TaskToEnv[taskName]
            if envKey and getgenv()[envKey] then
                local modeName = TaskToModeName[taskName]
                
                if modeName and isGamemodeOnCooldown(modeName) then
                    continue
                end
                
                return taskName
            end
        end
    end
    
    if getgenv().autoTeleportMonster then return "Farm Monsters" end
    return nil
end

local function autoDungeonFunction()
    while getgenv().autoDungeonEnabled do
        local topTask = getTopPriorityTask()
        if getgenv().enablePrioritySystem and topTask and topTask ~= "Auto Dungeon" then task.wait(1) else
            if not getPlayerGamemode() then
                if isGamemodeOnCooldown("Dungeon") then task.wait(2) continue end
                
                pcall(function() playerMap = tostring(ScriptLibrary.PlayerData.CurrentMap) end)
                local pMap = tostring(playerMap)
                if pMap ~= "1" and pMap ~= "4" and pMap ~= "Easter 2026 Event" and pMap ~= "Lobby" then getgenv().lastFarmMap = pMap end
                
                if tostring(playerMap) ~= "4" then
                    FireBridge("TeleportSystem", "To", 4)
                    task.wait(4.5)
                    pcall(function() playerMap = tostring(ScriptLibrary.PlayerData.CurrentMap) end)
                end
                teleportToGamemodeNPC(4, {"dungeon"})
                task.wait(1.5)
                local map = getgenv().selectedMapDungeon or "CrystalCave"
                local diff = getgenv().selectedDiffDungeon or "Easy"
                
                local w = 0
                while not getPlayerGamemode() and getgenv().autoDungeonEnabled and w < 12 and not isGamemodeOnCooldown("Dungeon") do
                    FireBridge("GamemodeSystem", "Create", "Dungeon", map:gsub("%s+", ""), diff)
                    task.wait(0.5)
                    FireBridge("GamemodeSystem", "Start", "Dungeon", player.UserId)
                    task.wait(2)
                    w = w + 2.5
