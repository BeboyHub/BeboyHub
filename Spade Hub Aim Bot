-- ==================== Main Loop ====================
RS.RenderStepped:Connect(function()
    FOVCircle.Visible = FOV_Visible
    FOVCircle.Radius = FOV_Radius
    FOVCircle.Position = UserInputService:GetMouseLocation()
    FOVCircle.Color = ESP_MainColor

    local target = nil
    local shortestDist = FOV_Radius

    for plr, draw in pairs(cacheESP) do
        local char = plr.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        local aimPosPart = char and char:FindFirstChild(AimPart)

        if char and root and hum and hum.Health > 0 and isEnemy(plr) then
            local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
            
            if onScreen then
                local size = (2000 / pos.Z)

                -- Aimlock Logic พร้อม Wall Check
                if AimlockEnabled and aimPosPart then
                    local mousePos = UserInputService:GetMouseLocation()
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < shortestDist then
                        -- เช็คว่าไม่ติดกำแพงก่อนถึงจะเลือกเป็นเป้าหมาย
                        if checkVisible(aimPosPart, char) then
                            shortestDist = dist
                            target = plr
                        end
                    end
                end

                -- ESP Logic
                if ESP_Enabled then
                    draw.box.Color = ESP_MainColor
                    draw.line.Color = ESP_MainColor
                    if ESP_Boxes then
                        draw.box.Visible, draw.boxOutline.Visible = true, true
                        draw.box.Size = Vector2.new(size, size * 1.5)
                        draw.box.Position = Vector2.new(pos.X - (size/2), pos.Y - (size*0.75))
                        draw.boxOutline.Size, draw.boxOutline.Position = draw.box.Size, draw.box.Position
                    else draw.box.Visible, draw.boxOutline.Visible = false, false end

                    if ESP_Names then
                        draw.name.Visible, draw.name.Text = true, string.format("%s [%d]", plr.Name, math.floor(hum.Health))
                        draw.name.Position = Vector2.new(pos.X, pos.Y - (size*0.75) - 18)
                    else draw.name.Visible = false end

                    if ESP_Tracers then
                        draw.line.Visible = true
                        draw.line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        draw.line.To = Vector2.new(pos.X, pos.Y + (size*0.75))
                    else draw.line.Visible = false end

                    if ESP_Skeleton then
                        local function setL(line, p1, p2)
                            if p1 and p2 then
                                local v1, o1 = Camera:WorldToViewportPoint(p1.Position); local v2, o2 = Camera:WorldToViewportPoint(p2.Position)
                                if o1 and o2 then line.Visible, line.From, line.To, line.Color = true, Vector2.new(v1.X, v1.Y), Vector2.new(v2.X, v2.Y), ESP_MainColor return end
                            end
                            line.Visible = false
                        end
                        local t = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                        local la, ra = char:FindFirstChild("LeftUpperArm") or char:FindFirstChild("Left Arm"), char:FindFirstChild("RightUpperArm") or char:FindFirstChild("Right Arm")
                        local ll, rl = char:FindFirstChild("LeftUpperLeg") or char:FindFirstChild("Left Leg"), char:FindFirstChild("RightUpperLeg") or char:FindFirstChild("Right Leg")
                        setL(draw.skeleton.h2t, char:FindFirstChild("Head"), t); setL(draw.skeleton.t2la, t, la); setL(draw.skeleton.t2ra, t, ra)
                        setL(draw.skeleton.t2ll, t, ll); setL(draw.skeleton.t2rl, t, rl)
                    else for _, l in pairs(draw.skeleton) do l.Visible = false end end
                else
                    draw.box.Visible, draw.boxOutline.Visible, draw.name.Visible, draw.line.Visible = false, false, false, false
                    for _, l in pairs(draw.skeleton) do l.Visible = false end
                end
            else
                draw.box.Visible, draw.boxOutline.Visible, draw.name.Visible, draw.line.Visible = false, false, false, false
                for _, l in pairs(draw.skeleton) do l.Visible = false end
            end
        else
            draw.box.Visible, draw.boxOutline.Visible, draw.name.Visible, draw.line.Visible = false, false, false, false
            for _, l in pairs(draw.skeleton) do l.Visible = false end
        end
    end

    -- Smooth Aimlock Execute
    if target and target.Character and target.Character:FindFirstChild(AimPart) then
        local goal = CFrame.lookAt(Camera.CFrame.Position, target.Character[AimPart].Position)
        Camera.CFrame = Camera.CFrame:Lerp(goal, 1/AimSmooth)
    end
end)

for _, v in pairs(Players:GetPlayers()) do createESP(v) end
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)
