local function getMonsterNames()
    local namesList = {}
    local duplicateChecker = {}
    pcall(function()
        local clientEnemies = workspace:FindFirstChild("_ENEMIES") and workspace._ENEMIES:FindFirstChild("Client")
        if clientEnemies then
            for _, uidFolder in pairs(clientEnemies:GetChildren()) do
                local billboard = uidFolder:FindFirstChild("EnemyBillboard", true)
                if billboard then
                    local title = billboard:FindFirstChild("Title")
                    if title and title:IsA("TextLabel") then
                        local mName = title.Text:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
                        if mName and mName ~= "" and not duplicateChecker[mName] then
                            duplicateChecker[mName] = true
                            table.insert(namesList, mName)
                        end
                    end
                end
            end
        end
    end)
    if #namesList == 0 then table.insert(namesList, "No Monsters Found") else table.sort(namesList) end
    return namesList
end

