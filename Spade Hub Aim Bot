local function checkMatch(current, targets)
    if not current or not targets then return false end
    local currStr = tostring(current):lower():gsub("[%s%p]", "")
    for k, v in pairs(targets) do
        if v then
            local targetStr = tostring(k):lower():gsub("[%s%p]", "")
            if currStr == targetStr or string.find(currStr, targetStr) then
                return true
            end
        end
    end
    return false
end

local function findGachaNPC(mapId, keywords)
    local interactions = workspace._MAP:FindFirstChild(tostring(mapId))
    if interactions then interactions = interactions:FindFirstChild("Interactions") end
    if not interactions then return nil end

    for _, v in ipairs(interactions:GetChildren()) do
        local attrName = tostring(v:GetAttribute("Name") or ""):lower()
        local attrId = tostring(v:GetAttribute("Id") or ""):lower()
        local modelName = tostring(v.Name):lower()

        for _, kw in ipairs(keywords) do
            local lowerKw = kw:lower()
            if string.find(attrName, lowerKw) or string.find(attrId, lowerKw) or string.find(modelName, lowerKw) then
                return v:FindFirstChild("Rig") or v:FindFirstChild("Range") or v
            end
        end
    end
    return nil
end

