WindUI:SetNotificationLower(true)
WindUI:SetTheme("AxelDark")

-- ==================== Services & Variables ====================
local RS = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local lp = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- State Variables
local AimlockEnabled = false
local AimPart = "HumanoidRootPart"
local AimSmooth = 1 
local FOV_Visible = true
local FOV_Radius = 150

local ESP_Enabled = false
local ESP_Boxes, ESP_Names, ESP_Tracers, ESP_Skeleton = false, false, false, false
local ESP_MainColor = Color3.fromRGB(139, 92, 246)

local cacheESP = {}

-- ==================== Helper Functions ====================
local function isEnemy(plr)
    if not plr or plr == lp or not plr.Character then return false end
    if not lp.Team or not plr.Team then return true end
    return plr.Team ~= lp.Team
end

local function checkVisible(targetPart, character)
    local castParams = RaycastParams.new()
    castParams.FilterType = Enum.RaycastFilterType.Exclude
    castParams.FilterDescendantsInstances = {lp.Character, character, Camera} -- ยกเว้นตัวเราและตัวศัตรู
    
    local ray = workspace:Raycast(Camera.CFrame.Position, (targetPart.Position - Camera.CFrame.Position), castParams)
    return ray == nil -- ถ้า ray เป็น nil แสดงว่าไม่มีอะไรกั้น
end

local function createDrawing(type, properties)
    local obj = Drawing.new(type)
    for i, v in pairs(properties) do obj[i] = v end
    return obj
end

-- ==================== ESP Management ====================
local function createESP(plr)
    if plr == lp then return end
    cacheESP[plr] = {
        box = createDrawing("Square", {Thickness = 1.5, ZIndex = 10, Filled = false}),
        boxOutline = createDrawing("Square", {Thickness = 3, Color = Color3.new(0,0,0), Transparency = 0.5, ZIndex = 9}),
        name = createDrawing("Text", {Size = 13, Outline = true, Center = true, ZIndex = 11, Color = Color3.new(1,1,1)}),
        line = createDrawing("Line", {Thickness = 1.2, Transparency = 0.6, ZIndex = 8}),
        skeleton = {
            h2t = createDrawing("Line", {Thickness = 1.5}), t2la = createDrawing("Line", {Thickness = 1.5}),
            t2ra = createDrawing("Line", {Thickness = 1.5}), t2ll = createDrawing("Line", {Thickness = 1.5}),
            t2rl = createDrawing("Line", {Thickness = 1.5})
        }
    }
end

local function removeESP(plr)
    if cacheESP[plr] then
        local d = cacheESP[plr]
        d.box:Remove(); d.boxOutline:Remove(); d.name:Remove(); d.line:Remove()
        for _, l in pairs(d.skeleton) do l:Remove() end
        cacheESP[plr] = nil
    end
end

local FOVCircle = createDrawing("Circle", {Thickness = 2, NumSides = 60, Transparency = 0.7})

