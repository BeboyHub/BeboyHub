local GachaToggles = {}

local function SetupGachaToggle(id, title, tokenName, mapDest, getTargetFunc, spinArgs)
    GachaToggles[id] = Tabs.Gacha:AddToggle(id, { Title = title, Default = false })
    GachaToggles[id]:OnChanged(function(value)
        getgenv()[id] = value
        if value then
            task.spawn(function()
                local teleported = false
                while getgenv()[id] do
                    if not teleported then
                        if tostring(playerMap) ~= tostring(mapDest) then
                            FireBridge("TeleportSystem", "To", tonumber(mapDest) or mapDest)
                            task.wait(2.5)
                        end
                        pcall(function()
                            local target = getTargetFunc()
                            if typeof(target) == "CFrame" then
                                if player.Character and player.Character.PrimaryPart then
                                    player.Character.PrimaryPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                    player.Character.PrimaryPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                    player.Character:SetPrimaryPartCFrame(target * CFrame.new(0, 3, 0))
                                    teleported = true
                                end
                            elseif target and player.Character and player.Character.PrimaryPart then
                                player.Character.PrimaryPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                                player.Character.PrimaryPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                                player.Character:SetPrimaryPartCFrame(GetGachaCFrame(target, 0, 0))
                                teleported = true
                            end
                        end)
                        task.wait(0.5)
                    end
                    
                    FireBridge(table.unpack(spinArgs))
                    task.wait(0.5)
                end
            end)
        end
    end)
end

