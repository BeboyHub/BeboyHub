local function setupAntiAfk()
    local Players = game:GetService("Players")
    local VirtualUser = game:GetService("VirtualUser")
    local CoreGui = game:GetService("CoreGui")
    local TeleportService = game:GetService("TeleportService")
    local GuiService = game:GetService("GuiService")

    Players.LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)

    pcall(function()
        for _, connection in pairs(getconnections(Players.LocalPlayer.Idled)) do
            if connection["Disable"] then
                connection:Disable()
            end
        end
    end)

    local function doRejoin()
        task.wait(2) 
        TeleportService:Teleport(game.PlaceId, Players.LocalPlayer)
    end

    task.spawn(function()
        pcall(function()
            local promptOverlay = CoreGui:WaitForChild("RobloxPromptGui"):WaitForChild("promptOverlay")
            promptOverlay.ChildAdded:Connect(function(child)
                if child.Name == "ErrorPrompt" then
                    doRejoin()
                end
            end)
        end)
    end)

    task.spawn(function()
        pcall(function()
            GuiService.ErrorMessageChanged:Connect(function()
                doRejoin()
            end)
        end)
    end)
end

task.spawn(function()
    local CoreGui = game:GetService("CoreGui")
    local TweenService = game:GetService("TweenService")
    local UserInputService = game:GetService("UserInputService")

    if CoreGui:FindFirstChild("MobileToggleGui") then
        CoreGui:FindFirstChild("MobileToggleGui"):Destroy()
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "MobileToggleGui"
    ScreenGui.Parent = CoreGui
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

    onUnload(function()
        if ScreenGui then ScreenGui:Destroy() end
    end)

    local ToggleButton = Instance.new("ImageButton")
    ToggleButton.Name = "ToggleButton"
    ToggleButton.Parent = ScreenGui
    ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    ToggleButton.BackgroundTransparency = 0
    ToggleButton.Position = UDim2.new(0.5, -25, 0, 20)
    ToggleButton.Size = UDim2.new(0, 50, 0, 50)
    ToggleButton.Image = "rbxassetid://86949082023913"
    ToggleButton.ZIndex = 100

    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0.5, 0)
    UICorner.Parent = ToggleButton

    local UIStroke = Instance.new("UIStroke")
    UIStroke.Color = Color3.fromRGB(255, 255, 255)
    UIStroke.Thickness = 1.5
    UIStroke.Transparency = 0.7
    UIStroke.Parent = ToggleButton

    local dragging = false
    local startPos = Vector2.new()
    local framePos = UDim2.new()
    local hasMoved = false

    local function update(input)
        local delta = input.Position - Vector3.new(startPos.X, startPos.Y, 0)
        ToggleButton.Position = UDim2.new(
            framePos.X.Scale, framePos.X.Offset + delta.X, 
            framePos.Y.Scale, framePos.Y.Offset + delta.Y
        )
    end

    ToggleButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            hasMoved = false
            startPos = Vector2.new(input.Position.X, input.Position.Y)
            framePos = ToggleButton.Position
            
            TweenService:Create(ToggleButton, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 42, 0, 42)}):Play()
            
            local moveConnection
            local releaseConnection

            moveConnection = UserInputService.InputChanged:Connect(function(moveInput)
                if (moveInput.UserInputType == Enum.UserInputType.MouseMovement or moveInput.UserInputType == Enum.UserInputType.Touch) and dragging then
                    if (Vector2.new(moveInput.Position.X, moveInput.Position.Y) - startPos).Magnitude > 10 then
                        hasMoved = true
                        update(moveInput)
                    end
                end
            end)

            releaseConnection = UserInputService.InputEnded:Connect(function(endInput)
                if endInput.UserInputType == Enum.UserInputType.MouseButton1 or endInput.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    moveConnection:Disconnect()
                    releaseConnection:Disconnect()
                    
                    TweenService:Create(ToggleButton, TweenInfo.new(0.4, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {Size = UDim2.new(0, 50, 0, 50)}):Play()
                    
                    if not hasMoved then
                        if Window then
                            Window:Minimize()
                        end
                    end
                end
            end)
        end
    end)
end)

onUnload(function() Unloaded = true end)
setupAntiAfk()
